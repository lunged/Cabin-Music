{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "cabin-svelte",
	"compatibility_date": "2026-06-03",
	// Worker runs in front of the static assets: it proxies /plex (Plex JSON, with CORS headers)
	// and serves the SPA for everything else via the ASSETS binding.
	"main": "worker/index.ts",
	"assets": {
		"directory": "./build",
		"not_found_handling": "single-page-application",
		"binding": "ASSETS"
	}
}
